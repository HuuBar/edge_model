WANDB_MODE=online
WANDB_PROJECT=industrial_posttrain_training
WANDB_API_KEY=replace-me

# GRPO reward uses a real LLM judge. Choose qwen, deepseek, or none.
# none is only for local plumbing checks; real training should use qwen or deepseek.
VERIFIER_PROVIDER=qwen

QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-max
QWEN_API_KEY=replace-me

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=replace-me

VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=models/original_model/Qwen3-8B
VLLM_NATIVE_TOOL_CALLING=false

LOCAL_HF_MODEL_PATH=models/original_model/Qwen3-8B
LOCAL_HF_MODEL_NAME=Qwen3-8B
